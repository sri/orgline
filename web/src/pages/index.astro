---
const renderedAt = new Date().toISOString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Orgline</title>
    <style>
      :root {
        color-scheme: light;
        font-family: "IBM Plex Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at 10% 20%, #f9e5c5 0%, transparent 42%),
          radial-gradient(circle at 90% 80%, #d5f0d7 0%, transparent 45%),
          linear-gradient(120deg, #f7f3eb, #f3f8ff);
      }

      main {
        width: min(42rem, 92vw);
        border: 1px solid #1d2a331a;
        border-radius: 14px;
        background: #ffffffcc;
        backdrop-filter: blur(4px);
        padding: 1.8rem;
        box-shadow: 0 12px 30px #0e25310d;
      }

      h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(2rem, 5vw, 2.8rem);
      }

      p {
        margin: 0.4rem 0;
        color: #23313f;
      }

      .meta {
        margin-top: 1rem;
        font-size: 0.9rem;
      }

      code {
        padding: 0.1rem 0.35rem;
        border-radius: 6px;
        background: #1d2a330f;
      }

      .outline {
        margin: 1rem 0 0;
        padding-left: 1.2rem;
      }

      .outline li {
        margin: 0.2rem 0;
        color: #1c2833;
      }

      .item-body {
        display: inline-block;
        padding: 0.15rem 0.45rem;
        border-radius: 6px;
        background: #ffffff;
        border: 1px solid #d8e3eb;
      }

      .error {
        color: #8a1c1c;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Workflow Outline</h1>
      <p id="outline-status">Loading items...</p>
      <div id="outline-root"></div>
      <p id="outline-error" class="error" hidden></p>
      <p class="meta">Astro rendered at <code>{renderedAt}</code></p>
    </main>
    <script type="module" src="/src/typescript/main.ts"></script>
  </body>
</html>
